<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instagram • Feed</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --bg-color: #000000;
            --card-bg: #121212;
            --border-color: #262626;
            --text-primary: #ffffff;
            --text-secondary: #a8a8a8;
            --accent-blue: #0095f6;
            --error-red: #ff3b30;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            padding-top: 70px; /* Space for fixed navbar */
            padding-bottom: 50px;
        }

        /* Fixed Navbar */
        .navbar {
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(10px);
            padding: 10px 20px;
            border-bottom: 1px solid var(--border-color);
            text-align: center;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .navbar h1 {
            font-size: 24px;
            font-family: 'Brush Script MT', cursive; /* Mimicking the logo font */
            font-weight: 500;
        }

        /* Container */
        .container {
            width: 100%;
            max-width: 470px;
            margin: 0 auto;
            padding: 0 10px;
        }

        /* Story Bar (Visual Filler) */
        .stories {
            display: flex;
            gap: 15px;
            padding: 15px 0;
            overflow-x: auto;
            margin-bottom: 10px;
        }

        .story {
            min-width: 66px;
            display: flex;
            flex-direction: column;
            align-items: center;
            font-size: 11px;
            color: var(--text-secondary);
        }

        .story-circle {
            width: 60px;
            height: 60px;
            background: linear-gradient(45deg, #f9ce34, #ee2a7b, #6228d7);
            border-radius: 50%;
            padding: 2px;
            margin-bottom: 5px;
        }

        .story-img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 2px solid #000;
            background: #333;
        }

        /* Post Card */
        .post {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            margin-bottom: 24px;
            border-radius: 8px;
            overflow: hidden;
        }

        .post-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: white;
        }

        .mini-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #444;
        }

        .username {
            font-weight: 600;
            font-size: 14px;
        }

        /* Media Placeholder */
        .post-media {
            width: 100%;
            aspect-ratio: 1/1;
            background: #222;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #444;
        }

        .post-media img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Post Actions */
        .post-footer {
            padding: 12px;
        }

        .action-icons {
            display: flex;
            gap: 15px;
            font-size: 22px;
            margin-bottom: 10px;
        }

        .post-content {
            font-size: 14px;
            line-height: 1.4;
            margin-bottom: 10px;
        }

        /* Edit/Delete Buttons Section */
        .admin-actions {
            display: flex;
            border-top: 1px solid var(--border-color);
            margin: 0 -12px -12px -12px;
        }

        .btn-action {
            flex: 1;
            padding: 12px;
            text-align: center;
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
            border-right: 1px solid var(--border-color);
            transition: background 0.2s;
        }

        .btn-action:last-child { border-right: none; }
        .view-btn { color: var(--text-primary); }
        .edit-btn { color: var(--accent-blue); }
        .delete-btn { color: var(--error-red); background: none; border: none; cursor: pointer; width: 100%; }

        .btn-action:hover { background: #1a1a1a; }

        /* Floating Create Button */
        .create-fab {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: var(--accent-blue);
            color: white;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 24px;
            box-shadow: 0 4px 15px rgba(0, 149, 246, 0.4);
            text-decoration: none;
            z-index: 1001;
        }

    </style>
</head>
<body>

    <nav class="navbar">
        <h1>Instagram</h1>
    </nav>

    <div class="container">
        
        <div class="stories">
            <div class="story">
                <div class="story-circle"><div class="story-img"></div></div>
                <span>Your Story</span>
            </div>
            <% posts.slice(0, 4).forEach(p => { %>
                <div class="story">
                    <div class="story-circle"><img src="https://i.pravatar.cc/100?u=<%= p.username %>" class="story-img"></div>
                    <span><%= p.username.substring(0, 8) %></span>
                </div>
            <% }) %>
        </div>

        <% posts.forEach((post)=>{ %>
            <div class="post">
                <div class="post-header">
                    <div class="user-info">
                        <img src="https://i.pravatar.cc/100?u=<%= post.username %>" class="mini-avatar">
                        <span class="username"><%= post.username %></span>
                    </div>
                    <i class="fa-solid fa-ellipsis"></i>
                </div>

                <div class="post-media">
                    <img src="https://picsum.photos/500/500?random=<%= post.id %>" alt="Post">
                </div>

                <div class="post-footer">
                    <div class="action-icons">
                        <i class="fa-regular fa-heart"></i>
                        <i class="fa-regular fa-comment"></i>
                        <i class="fa-regular fa-paper-plane"></i>
                    </div>
                    <div class="post-content">
                        <b><%= post.username %></b> <%= post.content %>
                    </div>
                    
                    <div class="admin-actions">
                        <a href="/posts/<%= post.id %>" class="btn-action view-btn">View Details</a>
                        <a href="/posts/<%= post.id %>/edit" class="btn-action edit-btn">Edit</a>
                        <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" style="flex:1">
                            <button class="btn-action delete-btn">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        <% }) %>

    </div>

    <a class="create-fab" href="/posts/new">
        <i class="fa-solid fa-plus"></i>
    </a>

</body>
</html>