<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Post • Instagram</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --bg-color: #000000;
            --card-bg: #121212;
            --border-color: #262626;
            --text-primary: #ffffff;
            --text-secondary: #a8a8a8;
            --accent-blue: #0095f6;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .create-post-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            width: 100%;
            max-width: 450px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.6);
        }

        .card-header {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card-header h2 {
            font-size: 16px;
            font-weight: 600;
            flex-grow: 1;
            text-align: center;
        }

        .card-header a {
            color: var(--text-primary);
            text-decoration: none;
            font-size: 14px;
        }

        /* Simulated Media Upload Area */
        .upload-placeholder {
            width: 100%;
            aspect-ratio: 4 / 3;
            background-color: #000;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: var(--text-secondary);
            border-bottom: 1px solid var(--border-color);
            cursor: pointer;
        }

        .upload-placeholder i {
            font-size: 40px;
            margin-bottom: 10px;
        }

        .form-content {
            padding: 16px;
        }

        .user-info {
            display: flex;
            align-items: center;
            margin-bottom: 16px;
        }

        .avatar-circle {
            width: 30px;
            height: 30px;
            background-color: #333;
            border-radius: 50%;
            margin-right: 12px;
        }

        .username-input {
            background: transparent;
            border: none;
            color: var(--text-primary);
            font-weight: 600;
            font-size: 14px;
            width: 100%;
        }

        .username-input:focus {
            outline: none;
        }

        textarea {
            width: 100%;
            min-height: 120px;
            background: transparent;
            border: none;
            color: var(--text-primary);
            font-size: 15px;
            resize: none;
            margin-bottom: 20px;
            line-height: 1.5;
        }

        textarea:focus {
            outline: none;
        }

        .btn-share {
            width: 100%;
            background-color: var(--accent-blue);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 10px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .btn-share:hover {
            opacity: 0.9;
        }

        .btn-share:active {
            transform: scale(0.98);
        }

        .discard-btn {
            display: block;
            text-align: center;
            margin-top: 15px;
            font-size: 14px;
            color: #ed4956; /* Red for Discard */
            text-decoration: none;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="create-post-card">
        <div class="card-header">
            <a href="/posts"><i class="fa-solid fa-arrow-left"></i></a>
            <h2>Create new post</h2>
            <div style="width: 20px;"></div> </div>

        <div class="upload-placeholder">
            <i class="fa-regular fa-images"></i>
            <p style="font-size: 14px;">Select from computer</p>
        </div>

        <form action="/posts" method="POST" class="form-content">
            
            <div class="user-info">
                <div class="avatar-circle"></div>
                <input type="text" name="username" class="username-input" placeholder="Enter username" required>
            </div>

            <textarea name="content" id="content" placeholder="Write a caption..."></textarea>

            <button type="submit" class="btn-share">Share</button>
            
            <a href="/posts" class="discard-btn">Discard</a>
        </form>
    </div>

</body>
</html>