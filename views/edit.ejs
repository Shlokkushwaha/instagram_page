<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post • Instagram</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --bg-color: #000000;
            --card-bg: #121212;
            --border-color: #262626;
            --text-primary: #ffffff;
            --text-secondary: #a8a8a8;
            --accent-blue: #0095f6;
            --input-bg: #1a1a1a;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .edit-container {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            width: 100%;
            max-width: 420px;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        }

        .header {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header h2 {
            font-size: 16px;
            font-weight: 600;
            flex-grow: 1;
            text-align: center;
        }

        .header a {
            color: var(--text-primary);
            text-decoration: none;
            font-size: 14px;
        }

        .form-body {
            padding: 20px;
        }

        /* Post Preview Thumbnail */
        .post-preview {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .thumb {
            width: 60px;
            height: 60px;
            border-radius: 4px;
            object-fit: cover;
            background: #333;
        }

        .thumb-info .username-label {
            font-weight: 700;
            font-size: 14px;
            display: block;
        }

        .thumb-info .editing-tag {
            font-size: 12px;
            color: var(--text-secondary);
        }

        /* Form Styling */
        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input[type="text"], 
        textarea {
            width: 100%;
            padding: 12px;
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-size: 14px;
            color: var(--text-primary);
            transition: border-color 0.2s;
        }

        input[type="text"]:focus, 
        textarea:focus {
            outline: none;
            border-color: #555;
        }

        input[readonly] {
            color: var(--text-secondary);
            cursor: not-allowed;
            opacity: 0.6;
        }

        textarea {
            resize: none;
            min-height: 150px;
        }

        .btn-update {
            width: 100%;
            background-color: var(--accent-blue);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 12px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .btn-update:hover {
            opacity: 0.9;
        }

        .btn-update:active {
            transform: scale(0.98);
        }

    </style>
</head>

<body>

    <div class="edit-container">
        <header class="header">
            <a href="/posts/<%= post.id %>"><i class="fa-solid fa-xmark"></i></a>
            <h2>Edit info</h2>
            <div style="width: 20px;"></div> </header>

        <form action="/posts/<%= post.id %>?_method=PATCH" method="POST" class="form-body">
            
            <div class="post-preview">
                <img src="https://picsum.photos/100/100?random=<%= post.id %>" class="thumb" alt="post preview">
                <div class="thumb-info">
                    <span class="username-label">@<%= post.username %></span>
                    <span class="editing-tag">Editing caption...</span>
                </div>
            </div>

            <div class="form-group">
                <label for="username">User</label>
                <input type="text" id="username" name="username" value="<%= post.username %>" readonly>
            </div>

            <div class="form-group">
                <label for="content">Caption</label>
                <textarea id="content" name="content" placeholder="Write a caption..."><%= post.content %></textarea>
            </div>

            <button type="submit" class="btn-update">Done</button>
        </form>
    </div>

</body>
</html>