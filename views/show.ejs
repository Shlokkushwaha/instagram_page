<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post Details • @<%= post.username %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --bg-color: #000000;
            --card-bg: #121212;
            --border-color: #262626;
            --text-primary: #ffffff;
            --text-secondary: #a8a8a8;
            --accent-blue: #0095f6;
            --error-red: #ff3b30;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .post-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            width: 100%;
            max-width: 500px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        /* Header */
        .post-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
        }

        .user-meta {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: inherit;
        }

        .story-ring {
            width: 42px;
            height: 42px;
            background: linear-gradient(45deg, #f9ce34, #ee2a7b, #6228d7);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2px;
        }

        .profile-pic {
            width: 100%;
            height: 100%;
            background-color: #333;
            border-radius: 50%;
            border: 2px solid var(--card-bg);
            object-fit: cover;
        }

        .username {
            font-size: 14px;
            font-weight: 700;
        }

        /* Image Content */
        .image-container {
            width: 100%;
            background-color: #000;
            position: relative;
        }

        .main-post-img {
            width: 100%;
            display: block;
            transition: transform 0.3s ease;
        }

        .main-post-img:hover {
            transform: scale(1.02);
        }

        /* Interaction Row */
        .interaction-bar {
            padding: 12px 16px;
            display: flex;
            justify-content: space-between;
            font-size: 24px;
        }

        .left-icons {
            display: flex;
            gap: 18px;
        }

        .icon-btn {
            cursor: pointer;
            transition: transform 0.1s;
        }

        .icon-btn:active {
            transform: scale(0.9);
            color: var(--text-secondary);
        }

        /* Caption & Text */
        .caption-section {
            padding: 0 16px 20px 16px;
        }

        .likes-count {
            font-weight: 700;
            font-size: 14px;
            margin-bottom: 6px;
            display: block;
        }

        .caption-text {
            font-size: 14px;
            line-height: 1.5;
        }

        .caption-text b {
            margin-right: 6px;
        }

        .time-ago {
            color: var(--text-secondary);
            font-size: 11px;
            text-transform: uppercase;
            margin-top: 10px;
            display: block;
        }

        /* Management Bar (Edit/Delete) */
        .admin-controls {
            display: flex;
            border-top: 1px solid var(--border-color);
        }

        .control-btn {
            flex: 1;
            padding: 14px;
            text-align: center;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            border-right: 1px solid var(--border-color);
            transition: background 0.2s;
        }

        .control-btn:last-child {
            border-right: none;
        }

        .edit-btn { color: var(--accent-blue); }
        .delete-btn { color: var(--error-red); }
        .back-btn { color: var(--text-secondary); }

        .control-btn:hover {
            background-color: #1a1a1a;
        }

    </style>
</head>
<body>

    <article class="post-card">
        <header class="post-header">
            <div class="user-meta">
                <div class="story-ring">
                    <img src="https://i.pravatar.cc/150?u=<%= post.username %>" class="profile-pic" alt="avatar">
                </div>
                <span class="username"><%= post.username %></span>
            </div>
            <i class="fa-solid fa-ellipsis icon-btn"></i>
        </header>

        <div class="image-container">
            <img src="https://picsum.photos/600/600?random=1" alt="Post Content" class="main-post-img">
        </div>

        <section class="interaction-bar">
            <div class="left-icons">
                <i class="fa-regular fa-heart icon-btn"></i>
                <i class="fa-regular fa-comment icon-btn"></i>
                <i class="fa-regular fa-paper-plane icon-btn"></i>
            </div>
            <i class="fa-regular fa-bookmark icon-btn"></i>
        </section>

        <section class="caption-section">
            <span class="likes-count">Liked by 1,482 people</span>
            <div class="caption-text">
                <b><%= post.username %></b> <%= post.content %>
            </div>
            <span class="time-ago">March 18, 2026</span>
        </section>

        <nav class="admin-controls">
            <a href="/posts" class="control-btn back-btn">
                <i class="fa-solid fa-chevron-left"></i> Feed
            </a>
            <a href="/posts/<%= post.id %>/edit" class="control-btn edit-btn">
                <i class="fa-regular fa-pen-to-square"></i> Edit
            </a>
            <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" style="flex: 1; display: flex;">
                <button type="submit" class="control-btn delete-btn" style="background: none; border: none; cursor: pointer; width: 100%;">
                    <i class="fa-regular fa-trash-can"></i> Delete
                </button>
            </form>
        </nav>
    </article>

</body>
</html>